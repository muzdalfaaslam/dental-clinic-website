# ─────────────────────────────────────────────────────────────────────────────
# TechxServe Med Spa Landing Page — environment variables
# Copy to `.env.local` and fill in. Every value below is optional for local dev:
# the app degrades gracefully (form logs to console, analytics no-op) when unset.
# ─────────────────────────────────────────────────────────────────────────────

# Where qualified leads are POSTed as JSON (CRM / Zapier / Make webhook).
# If unset, the API route logs the lead and returns success so the UI flow is testable.
LEAD_WEBHOOK_URL=

# GA4 Measurement ID, e.g. G-XXXXXXXXXX. Tag is skipped entirely if unset.
NEXT_PUBLIC_GA_ID=

# Meta (Facebook) Pixel ID. Pixel + Lead event are skipped entirely if unset.
NEXT_PUBLIC_META_PIXEL_ID=

# Absolute site URL used for canonical + Open Graph tags, e.g. https://medspa.techxserve.co
NEXT_PUBLIC_SITE_URL=http://localhost:3000
